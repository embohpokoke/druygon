# AI Provider API Keys
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Server Configuration
PORT=3847
HOST=127.0.0.1
NODE_ENV=production

# Cost Control (in USD)
MONTHLY_BUDGET_CAP=6.00
OPENAI_BUDGET_CAP=3.00
ANTHROPIC_BUDGET_CAP=3.00

# Rate Limiting
MAX_REQUESTS_PER_DAY=50
MAX_REQUESTS_PER_HOUR=15

# Provider Preferences
FALLBACK_ORDER=gemini,openai,anthropic
DEFAULT_PROVIDER=gemini

# OAuth Configuration
OAUTH_ENABLED=true
SESSION_SECRET=

# Google Cloud OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# PostgreSQL
POSTGRES_HOST=127.0.0.1
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
