# ═══════════════════════════════════════════════
# HYBRID AUTH - Choose One or Both
# ═══════════════════════════════════════════════

# OPTION 1: API Keys (Default - Recommended for single-user)
# Dapatkan: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# OPTION 2: OAuth (Optional - for multi-user or personal quotas)
OAUTH_ENABLED=false  # Set true to enable OAuth routes
SESSION_SECRET=change-this-to-random-string-in-production

# Google Cloud OAuth (if OAUTH_ENABLED=true)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OpenAI OAuth (if OAUTH_ENABLED=true)
OPENAI_CLIENT_ID=
OPENAI_CLIENT_SECRET=

# ═══════════════════════════════════════════════
# Server Configuration
# ═══════════════════════════════════════════════
PORT=3847
NODE_ENV=production

# Cost Control (in USD)
MONTHLY_BUDGET_CAP=6.00
OPENAI_BUDGET_CAP=3.00
ANTHROPIC_BUDGET_CAP=3.00

# Rate Limiting
MAX_REQUESTS_PER_DAY=50
MAX_REQUESTS_PER_HOUR=15

# Provider Preferences (comma-separated)
FALLBACK_ORDER=gemini,openai,anthropic
DEFAULT_PROVIDER=gemini
